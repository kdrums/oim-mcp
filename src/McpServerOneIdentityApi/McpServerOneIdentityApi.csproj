<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Version>1.0.0</Version>
    <AssemblyName>McpServerOneIdentityApi</AssemblyName>
    <Deterministic>true</Deterministic>
    <RepositoryType>git</RepositoryType>
    <RepositoryUrl>https://github.com/kdrums/claude-oim-mcp.git</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <!-- MCP host — same versions as claude-graph-mcp -->
    <PackageReference Include="ModelContextProtocol"                                    Version="1.1.0" />
    <PackageReference Include="Microsoft.Extensions.Hosting"                            Version="9.0.0" />

    <!-- Typed HttpClient factory for OIM REST calls -->
    <PackageReference Include="Microsoft.Extensions.Http"                               Version="9.0.0" />

    <!-- OAuth2 client-credentials flow against OIM RSTS (replaces Azure.Identity) -->
    <PackageReference Include="IdentityModel"                                           Version="7.0.0" />
  </ItemGroup>

</Project>
